# Custom OpenAI-compatible provider examples:
# AI_PROVIDER=custom
# AI_BASE_URL=https://example.com/v1
# AI_MODEL=Qwen3.5-2B
# OPENAI_API_KEY=optional-provider-key
# AI_CUSTOM_RESPONSE_FORMAT=off
