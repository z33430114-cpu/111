PORT=4173

# rules | openai | ollama | custom
AI_PROVIDER=ollama
AI_MODEL=qwen2.5:7b
AI_BASE_URL=http://127.0.0.1:11434
AI_CUSTOM_RESPONSE_FORMAT=auto

# OpenAI provider
OPENAI_API_KEY=
OPENAI_RECOMMENDER_MODEL=gpt-5.5

# Ollama provider examples:
